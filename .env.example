# VoxelSwarm — Environment Configuration
# Copy to .env and edit values.
# Most settings are stored in the SQLite database (settings table).
# This file handles only pre-database bootstrap values.

APP_ENV=production
APP_DEBUG=false

# Optional bootstrap fallbacks used before database settings are available.
# base_domain is the workspace domain: demo.ricsian.com, client.ricsian.com.
BASE_DOMAIN=ricsian.com

# control_app_url is the management/provisioning app: operator, API, status pages.
CONTROL_APP_URL=https://app.ricsian.com
